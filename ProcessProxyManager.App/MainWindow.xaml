<Window x:Class="ProcessProxyManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:app="clr-namespace:ProcessProxyManager.App"
        xmlns:core="clr-namespace:ProcessProxyManager.Core;assembly=ProcessProxyManager.Core"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="ProxyPilot"
        Height="820"
        Width="1360"
        MinHeight="680"
        MinWidth="1120"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="14"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <app:BindingProxy x:Key="VmProxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FA" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="SoftSurfaceBrush" Color="#EEF3F8" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D8E0EA" />
        <SolidColorBrush x:Key="BorderBrushMuted" Color="#E6EBF1" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#586475" />
        <SolidColorBrush x:Key="TertiaryTextBrush" Color="#7A8696" />
        <SolidColorBrush x:Key="AccentBrush" Color="#28668E" />
        <SolidColorBrush x:Key="AccentBrushHover" Color="#1E5479" />
        <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="HealthyBrush" Color="#DFF3E6" />
        <SolidColorBrush x:Key="HealthyTextBrush" Color="#1E5A37" />
        <SolidColorBrush x:Key="InfoBrush" Color="#E4F0FA" />
        <SolidColorBrush x:Key="InfoTextBrush" Color="#245476" />
        <SolidColorBrush x:Key="WarningBrush" Color="#FFF6DC" />
        <SolidColorBrush x:Key="WarningTextBrush" Color="#76530B" />

        <ObjectDataProvider x:Key="ProxyActions"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="core:ProxyAction" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="PanelCard" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="CompactPanelCard" TargetType="{x:Type Border}" BasedOn="{StaticResource PanelCard}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="TinyMutedText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource MutedText}">
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="StatusPill" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushMuted}" />
            <Setter Property="Background" Value="{DynamicResource SoftSurfaceBrush}" />
        </Style>

        <Style x:Key="StatusText" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="104" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="6,0,0,6" />
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="FontWeight" Value="Normal" />
        </Style>

        <Style x:Key="WideSecondaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="GridActionButton" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="FieldTextBox" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,4,0,10" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushSoft}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13.5" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="{DynamicResource SubtleSurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushMuted}" />
            <Setter Property="Padding" Value="8,7" />
        </Style>

        <Style TargetType="{x:Type DataGridRow}">
            <Setter Property="MinHeight" Value="54" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="AppIcon" Width="34" Height="34" Margin="0,0,10,0" />
                    <StackPanel>
                        <TextBlock Text="ProxyPilot" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="{Binding VersionLabel}" Foreground="{DynamicResource TertiaryTextBrush}" FontSize="13" />
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{Binding [BtnRefresh]}" Command="{Binding RefreshProcessesCommand}" Style="{StaticResource SecondaryButton}" />
                    <Button Content="{Binding [BtnSave]}" Command="{Binding SaveRulesCommand}" Style="{StaticResource SecondaryButton}" />
                    <Button Content="{Binding [BtnApply]}" Command="{Binding ApplyRulesCommand}" Style="{StaticResource PrimaryButton}" />
                    <Button Content="{Binding LanguageButtonText}" Command="{Binding ToggleLanguageCommand}" Style="{StaticResource SecondaryButton}" MinWidth="76" />
                </WrapPanel>

                <WrapPanel Grid.Row="2" Grid.ColumnSpan="2">
                    <Border Style="{StaticResource StatusPill}" Background="{DynamicResource HealthyBrush}">
                        <TextBlock Text="{Binding MihomoRuntimeStatus}" Foreground="{DynamicResource HealthyTextBrush}" Style="{StaticResource StatusText}" />
                    </Border>
                    <Border Style="{StaticResource StatusPill}" Background="{DynamicResource InfoBrush}">
                        <TextBlock Text="{Binding ApiStatus}" Foreground="{DynamicResource InfoTextBrush}" Style="{StaticResource StatusText}" />
                    </Border>
                    <Border Style="{StaticResource StatusPill}" Background="{DynamicResource WarningBrush}">
                        <TextBlock Text="{Binding TunStatus}" Foreground="{DynamicResource WarningTextBrush}" Style="{StaticResource StatusText}" />
                    </Border>
                    <Border Style="{StaticResource StatusPill}">
                        <TextBlock Text="{Binding TrafficTakeoverStatus}" Style="{StaticResource StatusText}" />
                    </Border>
                    <Border Style="{StaticResource StatusPill}">
                        <TextBlock Text="{Binding UpstreamHealthStatus}" Style="{StaticResource StatusText}" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Left" Text="{Binding [Processes]}" Style="{StaticResource SectionTitle}" Margin="0" />
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ProcessCountText}" Foreground="{DynamicResource SecondaryTextBrush}" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="2"
                                  HorizontalScrollBarVisibility="Visible"
                                  VerticalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                    <DataGrid MinWidth="1728"
                              ItemsSource="{Binding ProcessGroups}"
                              SelectedItem="{Binding SelectedProcess}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeaderWidth="0"
                              RowDetailsVisibilityMode="Visible"
                              AlternatingRowBackground="{DynamicResource SubtleSurfaceBrush}"
                              Background="{DynamicResource SurfaceBrush}"
                              BorderThickness="0"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrushMuted}"
                              HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrushMuted}"
                                        BorderThickness="0,1,0,1"
                                        Padding="74,8,10,8"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                    <ItemsControl ItemsSource="{Binding Processes}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="190" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13.5" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding ProcessId}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding DisplayPath}" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{Binding Data[ColProcess], Source={StaticResource VmProxy}}" Width="260" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center" Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Content="{Binding ExpandGlyph}"
                                                    Command="{Binding ToggleExpandedCommand}"
                                                    Visibility="{Binding CanExpand, Converter={StaticResource BoolToVisibility}}"
                                                    Width="22"
                                                    Height="22"
                                                    Padding="0"
                                                    Margin="0,0,4,0"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                                    FontWeight="SemiBold" />
                                            <Image Grid.Column="1" Source="{Binding Icon}" Width="24" Height="24" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="14.5" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding CountBadge}" Margin="5,0,0,0" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Subtitle}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12.5" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PID" Binding="{Binding PrimaryProcessId}" Width="92" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColPath], Source={StaticResource VmProxy}}" Binding="{Binding DisplayPath}" Width="180" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="{Binding Data[ColActions], Source={StaticResource VmProxy}}" Width="306">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="PROXY" Command="{Binding SetProxyCommand}" Style="{StaticResource GridActionButton}" />
                                            <Button Content="DIRECT" Command="{Binding SetDirectCommand}" Style="{StaticResource GridActionButton}" />
                                            <Button Content="REJECT" Command="{Binding SetRejectCommand}" Style="{StaticResource GridActionButton}" />
                                            <Button Content="{Binding Data[BtnClear], Source={StaticResource VmProxy}}" Command="{Binding ClearRuleCommand}" Style="{StaticResource GridActionButton}" MinWidth="42" Margin="0" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridComboBoxColumn Header="{Binding Data[ColRule], Source={StaticResource VmProxy}}"
                                                    Width="132"
                                                    ItemsSource="{Binding Source={StaticResource ProxyActions}}"
                                                    SelectedItemBinding="{Binding SelectedAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="{Binding Data[ColConn], Source={StaticResource VmProxy}}" Binding="{Binding CurrentConnectionCount}" Width="66" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColMihomo], Source={StaticResource VmProxy}}" Binding="{Binding MihomoConnectionCount}" Width="78" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColUpstream], Source={StaticResource VmProxy}}" Binding="{Binding UpstreamConnectionCount}" Width="86" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColRuleHit], Source={StaticResource VmProxy}}" Binding="{Binding LastMatchedRule}" Width="190" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColRoute], Source={StaticResource VmProxy}}" Binding="{Binding LastRouteChain}" Width="260" IsReadOnly="True" />
                            <DataGridTextColumn Header="{Binding Data[ColSuspect], Source={StaticResource VmProxy}}" Binding="{Binding SuspectedDirectConnectionCount}" Width="98" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [SelectedProcess]}" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding SelectedProcess.DisplayName, TargetNullValue=None}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding SelectedProcess.ProcessIdSummary}" Style="{StaticResource MutedText}" />
                            <TextBlock Margin="0,4,0,10" Text="{Binding SelectedProcess.DisplayPath}" Style="{StaticResource MutedText}" />
                            <TextBlock Text="{Binding [Rule]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <ComboBox Margin="0,4,0,0"
                                      Height="30"
                                      ItemsSource="{Binding Source={StaticResource ProxyActions}}"
                                      SelectedItem="{Binding SelectedProcess.SelectedAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [RouteChain]}" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding RouteChainStatus}" Style="{StaticResource MutedText}" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding SelectedProcess.LastRouteChain}" Style="{StaticResource TinyMutedText}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="mihomo" Style="{StaticResource SectionTitle}" />
                            <UniformGrid Columns="2">
                                <Button Content="{Binding [BtnCheckApi]}" Command="{Binding CheckApiCommand}" Style="{StaticResource WideSecondaryButton}" Margin="0,0,6,8" />
                                <Button Content="{Binding [BtnStartMihomo]}" Command="{Binding StartMihomoCommand}" Style="{StaticResource WideSecondaryButton}" Margin="6,0,0,8" />
                                <Button Content="{Binding [BtnStopMihomo]}" Command="{Binding StopMihomoCommand}" Style="{StaticResource WideSecondaryButton}" Margin="0,0,6,0" />
                                <Button Content="{Binding [BtnRestartMihomo]}" Command="{Binding RestartMihomoCommand}" Style="{StaticResource WideSecondaryButton}" Margin="6,0,0,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [UpstreamProxy]}" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding UpstreamProxyStatus}" Style="{StaticResource MutedText}" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding UpstreamHealthStatus}" Style="{StaticResource MutedText}" />
                            <TextBlock Margin="0,4,0,8" Text="{Binding UpstreamHealthDetails}" Style="{StaticResource TinyMutedText}" />
                            <UniformGrid Columns="2">
                                <Button Content="{Binding [BtnDetectProxy]}" Command="{Binding DetectUpstreamProxyCommand}" Style="{StaticResource WideSecondaryButton}" Margin="0,0,6,8" />
                                <Button Content="{Binding [BtnCheckUpstream]}" Command="{Binding CheckUpstreamHealthCommand}" Style="{StaticResource WideSecondaryButton}" Margin="6,0,0,8" />
                            </UniformGrid>
                            <CheckBox Content="{Binding [AutoDetectProxy]}" IsChecked="{Binding AutoDetectUpstreamProxy}" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="76" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding [ProxyType]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding UpstreamProxyType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding [ProxyHost]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding UpstreamProxyHost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="{Binding [ProxyPort]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    <TextBox Text="{Binding UpstreamProxyPort, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [ConnectionDetection]}" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="{Binding TunLoopbackStatus}" Style="{StaticResource MutedText}" />
                            <TextBlock Margin="0,6,0,8" Text="{Binding ChromeReloadHint}" Style="{StaticResource TinyMutedText}" />
                            <Button Content="{Binding [BtnInspectConnections]}" Command="{Binding InspectConnectionsCommand}" Style="{StaticResource WideSecondaryButton}" />
                            <Button Content="{Binding [BtnRestartSelectedProcess]}" Command="{Binding RestartSelectedProcessCommand}" Style="{StaticResource WideSecondaryButton}" Margin="0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [Settings]}" Style="{StaticResource SectionTitle}" />
                            <TextBlock Text="mihomo.exe" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding MihomoPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                            <Button Content="{Binding [BtnLocateMihomo]}" Command="{Binding LocateMihomoCommand}" Style="{StaticResource WideSecondaryButton}" />
                            <TextBlock Text="{Binding [TemplateConfig]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding TemplateConfigPath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                            <TextBlock Text="{Binding [GeneratedConfig]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding GeneratedConfigPath, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FieldTextBox}" />
                            <TextBlock Text="API URL" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                            <TextBlock Text="{Binding [Secret]}" Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBox Text="{Binding Secret, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}" />
                            <CheckBox Content="{Binding [EnableTun]}" IsChecked="{Binding EnableTun}" Margin="0,2,0,6" />
                            <CheckBox Content="{Binding [StopOnExit]}" IsChecked="{Binding CloseMihomoOnExit}" Margin="0,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CompactPanelCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding [Language]}" Style="{StaticResource SectionTitle}" />
                            <Button Content="{Binding LanguageButtonText}" Command="{Binding ToggleLanguageCommand}" Style="{StaticResource WideSecondaryButton}" />
                            <Expander Header="{Binding [Files]}" Margin="0,4,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{Binding RulesFilePath}" Style="{StaticResource TinyMutedText}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding RuleSnippetPath}" Style="{StaticResource TinyMutedText}" />
                                    <TextBlock Margin="0,6,0,0" Text="{Binding SettingsFilePath}" Style="{StaticResource TinyMutedText}" />
                                </StackPanel>
                            </Expander>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="10">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Text="{Binding RuleStatus}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="12,0,0,0" />
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
